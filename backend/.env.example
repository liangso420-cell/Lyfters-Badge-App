MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/lyfter?retryWrites=true&w=majority
JWT_SECRET=genera-un-secret-seguro-aqui-minimo-32-caracteres
PORT=5000
FLASK_ENV=production

# En producción: dominio(s) del frontend separados por coma.
# Ej: https://liangso420-cell.github.io,https://tu-app.vercel.app
CORS_ORIGINS=https://liangso420-cell.github.io

# ── Rate Limiting ──
# Backend de almacenamiento para flask-limiter en producción.
# Render + Upstash Redis: obtén la URL en upstash.com → tu base → REST URL (redis://)
REDIS_URL=redis://default:password@tu-instancia.upstash.io:6379

# ── URLs ──
# URL BASE del FRONTEND (GitHub Pages, Vercel, etc. — NO del backend).
# Los QR generados apuntarán a: APP_BASE_URL/redeem.html?event={event_id}&token={token}
APP_BASE_URL=https://liangso420-cell.github.io/Lyfters-Badge-App

# URL del frontend usada en emails (reset de contraseña, invitaciones).
FRONTEND_URL=https://liangso420-cell.github.io/Lyfters-Badge-App

# ── Email (Resend) ──
# Obtén tu key en resend.com → API Keys.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google / Firebase ──
# Web Client ID de Google OAuth (Google Cloud Console → APIs → Credentials).
# Se usa para verificar el idToken que envía Firebase al hacer login con Google.
FIREBASE_CLIENT_ID=538632921235-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
