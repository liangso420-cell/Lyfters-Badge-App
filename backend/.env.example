# Copia este archivo como .env y completa los valores reales.

# Cadena de conexión a MongoDB Atlas
MONGO_URI=
# Nombre de la base de datos
MONGO_DB=lyfter_badges

# Secreto para firmar los JWT (usa un valor largo y aleatorio en producción)
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
# Horas de validez del token (cubre la duración del evento)
JWT_EXP_HOURS=24

# Puerto del servidor Flask
PORT=5000

# URL pública del FRONTEND (Vercel) — se usa para construir la URL del QR
FRONTEND_URL=http://localhost:5173

# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173
