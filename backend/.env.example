MONGO_URI=
JWT_SECRET=cambia_esto_por_un_secreto_seguro
PORT=5000
FLASK_ENV=development
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ── Seguridad (solo se usa cuando FLASK_ENV != development) ──
# Backend de almacenamiento para rate limiting (flask-limiter).
REDIS_URL=
# En PRODUCCIÓN reemplazá CORS_ORIGINS de arriba por el dominio del frontend:
# CORS_ORIGINS=https://tu-app.vercel.app

# URL BASE del FRONTEND (NO del backend).
# Los QR generados apuntarán a: APP_BASE_URL/redeem.html?event={event_id}&token={token}
# Dev:  APP_BASE_URL=
# Prod: APP_BASE_URL=
APP_BASE_URL=

# Web Client ID de Google OAuth (Google Cloud Console → APIs → Credentials).
# Se usa para verificar el idToken que envía Firebase al hacer login con Google.
FIREBASE_CLIENT_ID=
